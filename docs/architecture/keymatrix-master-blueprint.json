        "manifest_management"
      ],
      "data_plane": [
        "processing",
        "analytics",
        "storage",
        "streaming",
        "external_sync"
      ]
    },
    "layers": {
      "L1_core": ["MetaCore", "PrimeCore", "MindState", "Singularity", "Archivarius"],
